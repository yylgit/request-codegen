{
  "name": "@vibefe/request-codegen",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "request-codegen": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "changeset": "changeset",
    "version": "changeset version",
    "publish:changeset": "changeset publish",
    "verify:version": "node scripts/check-version-change.js",
    "generate": "tsx src/cli.ts",
    "generate:test": "tsx src/cli.ts --input test/users.swagger.json --out test/react-app/src/generated",
    "test:app:install": "cd test/react-app && pnpm install",
    "test:app:dev": "cd test/react-app && pnpm dev",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {},
  "peerDependencies": {
    "axios": "^1.0.0",
    "@tanstack/react-query": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@changesets/cli": "^2.25.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.6"
  }
}
